{
  "name": "imptfc-client",
  "version": "0.1.0",
  "private": true,
  "description": "International Montpellier FC Client",
  "scripts": {
    "dev": "vite --port 8080 --mode=development",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^2.3.2",
    "autoprefixer": "^10.4.7",
    "axios": "0.19.0",
    "funql-api": "^1.2.9",
    "moment": "^2.29.3",
    "moment-timezone": "^0.5.27",
    "pug": "^3.0.2",
    "sass": "^1.43.4",
    "vite": "^2.9.8",
    "vite-plugin-require-transform": "^1.0.3",
    "vue": "^3.2.33",
    "vue-helmet": "^1.1.5",
    "vue-router": "^4.0.15",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "eslint": "^5.16.0",
    "eslint-plugin-vue": "^5.2.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "rules": {},
    "parserOptions": {
      "parser": "babel-eslint"
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "keywords": []
}
